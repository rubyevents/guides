#!/usr/bin/env bash
# Regenerate the social share image (assets/images/og.png) from the /og/ page.
# Edit og/index.html, preview it at http://localhost:4000/og/ via `jekyll serve`,
# then run this script to export the PNG. Avatars come from _data/voices.yml.
set -euo pipefail
cd "$(dirname "$0")/.."

port=4999
out=assets/images/og.png

chrome=$(command -v chromium || command -v chromium-browser \
  || command -v google-chrome || command -v google-chrome-stable || true)
if [ -z "$chrome" ]; then
  echo "error: no chromium/chrome found on PATH" >&2
  exit 1
fi

echo "Building site..."
bundle exec jekyll build >/dev/null

echo "Serving _site on :$port ..."
ruby -run -e httpd _site -p "$port" >/dev/null 2>&1 &
server=$!
trap 'kill "$server" 2>/dev/null || true' EXIT
sleep 2

echo "Capturing $out ..."
"$chrome" --headless --disable-gpu --hide-scrollbars --no-sandbox \
  --force-device-scale-factor=1 --window-size=1200,630 \
  --virtual-time-budget=4000 \
  --screenshot="$out" \
  "http://localhost:$port/og/" >/dev/null 2>&1

echo "Wrote $out ($(identify -format '%wx%h' "$out" 2>/dev/null || echo '?'))"
